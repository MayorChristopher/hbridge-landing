{
  "expo": {
    "scheme": "hbridge",
    "name": "Hbridge",
    "slug": "hbridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/hbridge3.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#083236",
    "splash": {
      "image": "./assets/hbridge3.png",
      "resizeMode": "contain",
      "backgroundColor": "#083236"
    },
    "androidStatusBar": {
      "backgroundColor": "#083236",
      "barStyle": "light-content"
    },

    "assetBundlePatterns": [
      "**/*"
    ],
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/990675ce-f2c2-4d23-abc3-651fe28c74dd",
      "enabled": true,
      "checkAutomatically": "ON_LOAD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hbridge.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Hbridge needs microphone access to record voice messages during telehealth consultations.",
        "NSPhotoLibraryAddUsageDescription": "Hbridge needs photo library access to save medical record images.",
        "NSPhotoLibraryUsageDescription": "Hbridge needs photo library access for profile pictures and medical documents."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/hbridge3.png",
        "backgroundColor": "#083236"
      },
      "package": "com.hbridge.app.v2",
      "versionCode": 3,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/hbridge3.png"
    },
    "owner": "bridge-app",
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#083236",
          "image": "./assets/hbridge3.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#083236",
            "image": "./assets/hbridge3.png"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/hbridge3.png",
          "color": "#0B7E8A"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "This app needs access to location for emergency services and finding nearby hospitals."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "This app needs access to camera to take photos for medical records."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "This app needs access to photos for profile pictures and medical documents."
        }
      ]
