{
  "name": "hbridge",
  "version": "1.0.0",
  "main": "index.ts",
  "web": {
    "bundler": "metro"
  },
  "scripts": {
    "start": "npx expo start",
    "web": "npx expo start --web",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "build:dev": "npx eas build --platform android --profile development",
    "build:android": "npx eas build --platform android --profile production --clear-cache",
    "build:ios": "npx eas build --platform ios --clear-cache",
    "build:web": "npx expo export:web",
    "submit:android": "npx eas submit --platform android",
    "submit:ios": "npx eas submit --platform ios"
  },
