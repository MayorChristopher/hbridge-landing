{
  "scripts": {
    "start": "expo start",
    "start-clear": "expo start --clear --reset-cache",
    "start-tunnel": "expo start --tunnel",
    "start-localhost": "expo start --localhost",
    "start-offline": "expo start --offline",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "fix-network": "npm cache clean --force && expo start --tunnel --clear",
    "reset-all": "rm -rf node_modules && npm install && expo start --clear"
  }
}